# ========================================
# MONGODB CONNECTION STRING - INSTRUCTIONS
# ========================================
#
# YOUR CURRENT CONNECTION IS NOT WORKING!
#
# TO FIX:
# 1. Go to https://cloud.mongodb.com
# 2. Login to your MongoDB Atlas account
# 3. Click "Database" → Find your cluster
# 4. Click "Connect" button
# 5. Choose "Connect your application"
# 6. Copy the connection string
# 7. Replace <password> with YOUR REAL password
# 8. Add database name: /travelgo after .mongodb.net/
#
# CORRECT FORMAT:
# mongodb+srv://username:password@cluster.xxxxx.mongodb.net/travelgo?retryWrites=true&w=majority
#
# EXAMPLE:
# mongodb+srv://john:MyPass123@cluster0.abc12.mongodb.net/travelgo?retryWrites=true&w=majority
#
# ========================================

MONGO_URL=mongodb+srv://aishwaryas2024cce_db_user:YOUR_REAL_PASSWORD_HERE@YOUR_REAL_CLUSTER.mongodb.net/travelgo?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=travelgo_super_secret_jwt_key_2024
NODE_ENV=development

# ========================================
# AFTER UPDATING MONGO_URL:
# 1. Save this file
# 2. Run: node test-connection.js
