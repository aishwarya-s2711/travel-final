# TravelGo Production Environment Variables (Vercel)

# MongoDB Connection String (Atlas recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/travelgo?retryWrites=true&w=majority

# JWT Secret for authentication (Use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# For Vercel Serverless (automatically injected by Vercel, but good for reference)
# VERCEL=1
# NODE_ENV=production

# Frontend API URL (In Vercel, relative paths work perfectly for same-domain)
VITE_API_URL=/api
